# ملاحظة: .gitignore لا يوقف تتبّع ملفات «مضافة مسبقاً» للمستودع.
# لإزالة الملفات من Git مع الإبقاء عليها على الجهاز ثم دفع التغيير:
#   git rm -r --cached env/ media/  &&  git rm --cached db.sqlite3
#   git ls-files | grep __pycache__ | xargs git rm --cached   (أو نفس الفكرة لأي مسار)
# ثم: git commit -m "Stop tracking ignored paths"



# --- Virtual environments ---
env/
venv/
.venv/
ENV/

# --- Django: secrets & local overrides ---
*.log
.env
.env.*
.git
.idea



# --- User uploads & generated media (احتفظ بها على السيرفر؛ لا تستبدلها بـ git pull) ---


# --- Collected static (يُعاد إنشاؤها بـ collectstatic على السيرفر) ---




# --- IDE & OS ---
.idea/
.vscode/
